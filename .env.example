# =============================================================================
# CommerceAI OS — Environment Variable Template
# Copy to .env for local development. NEVER commit real secrets.
# =============================================================================

# --- Runtime ---
NODE_ENV=development
APP_ENV=local
APP_NAME=commerceai-os
APP_VERSION=0.0.0
LOG_LEVEL=debug
LOG_FORMAT=json

# --- HTTP ---
API_HOST=0.0.0.0
API_PORT=3000
WEB_PORT=3001
ADMIN_PORT=3002
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# --- Database (placeholders only) ---
DATABASE_URL=postgresql://commerceai:commerceai@localhost:5432/commerceai_local
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_SSL=false

# --- Cache ---
REDIS_URL=redis://localhost:6379/0

# --- Messaging / queues (placeholders) ---
QUEUE_URL=
QUEUE_REGION=us-east-1

# --- Object storage ---
S3_BUCKET_MEDIA=
S3_BUCKET_EXPORTS=
S3_ENDPOINT=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Auth (placeholders — implement later) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Feature flags ---
FEATURE_FLAGS_PROVIDER=config
FEATURE_AI_WRITES_ENABLED=false
FEATURE_EBAY_SYNC_ENABLED=false

# --- AI providers (placeholders — no real keys) ---
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_DEFAULT_MODEL=
AI_BUDGET_DAILY_USD=0
AI_MAX_CONCURRENCY=2

# --- Integrations (placeholders) ---
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_ENV=sandbox
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Observability ---
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=commerceai-os
SENTRY_DSN=

# --- Multi-tenant ---
DEFAULT_WORKSPACE_SLUG=demo
TENANCY_ENFORCEMENT=true
