# CommerceAI OS API — Environment template (never commit real secrets)

APP_NAME=commerceai-api
APP_ENV=local
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=console
LOG_JSON=false

API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_DOCS_ENABLED=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
ALLOWED_HOSTS=["*"]

# PostgreSQL (async)
DATABASE_URL=postgresql+asyncpg://commerceai:commerceai@localhost:5432/commerceai_local
DATABASE_ECHO=false
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_STARTUP_VALIDATE=false
DATABASE_STARTUP_STRICT=false

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=commerceai:

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=false

# Security placeholders (auth not implemented)
SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting (placeholder)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_DEFAULT=100/minute

# Multi-tenancy
TENANCY_ENFORCEMENT=true
DEFAULT_TENANT_HEADER=X-Workspace-Id

# Feature flags
FEATURE_AI_WRITES_ENABLED=false
FEATURE_EBAY_SYNC_ENABLED=false
FEATURE_PLUGIN_RUNTIME=false
FEATURE_BILLING_ENABLED=false

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=commerceai-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_SAMPLER_ARG=1.0

# External placeholders (not used in foundation)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
LLM_API_KEY=
S3_BUCKET=
